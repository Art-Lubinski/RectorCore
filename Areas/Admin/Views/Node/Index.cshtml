@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

}
@model RectorCore.Models.Node
<div class="container-fluid ">
    <ul class="nav nav-pills justify-content-center">
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewData["location"].ToString() == "NY" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="NY">NY</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewData["location"].ToString() == "TX" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="TX">TX</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewBag.Location.ToString() == "FL" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="FL">FL</a>
        </li>
        <li class="nav-item active">
            <a class="nav-link @(ViewContext.ViewBag.Location.ToString() == "CA" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="CA">CA</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewBag.Location.ToString() == "IL" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="IL">IL</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewBag.Location.ToString() == "OH" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="OH">OH</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewBag.Location.ToString() == "AL" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="AL">AL</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewBag.Location.ToString() == "WA" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="WA">WA</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewBag.Location.ToString() == "AZ" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="AZ">AZ</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewBag.Location.ToString() == "AUS" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="AUS">AUS</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewBag.Location.ToString() == "CAN" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="CAN">CAN</a>
        </li>
    </ul>
    <div class="row">
        <div class="col-md-10">
            <div class="row ">
                <div class="col-6">
                    <div class="row">
                        <div class="col-6">
                            <div class="card">
                                <div class="card-header text-center">
                                    <h5 class="card-title text-gray">Info</h5>
                                </div>
                                <div class="card-body">
                                    <form>
                                        <div class="row">
                                            <div class="col-12">
                                                <div class="form-group">
                                                    <div class="form-group bmd-form-group">
                                                        <label class="bmd-label-floating">Status</label>
                                                        <input class="form-control" type="text" readonly value="Active">
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="clearfix"></div>
                                    </form>
                                </div>
                            </div>
                            @if (Model.TVID != "")
                            {
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title text-md-center text-gray">Team Viewer</h5>

                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-4 text-center">
                                                <img alt="svgImg" src="data:image/svg+xml;base64,">
                                            </div>
                                            <div class="col-md-8 text-left">
                                                <span class="small">
                                                    @Model.TVID
                                                </span>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-4 text-center">
                                                <span class="small">
                                                    <i class="material-icons">lock</i>
                                                </span>
                                            </div>
                                            <div class="col-md-8 text-left">
                                                <span class="small">
                                                    12312412345
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                            @if (Model.AnydeskID != "")
                            {
                                <div class="card">
                                    <div class="card-header">
                                        <h5 class="card-title text-md-center text-gray">AnyDesk</h5>

                                    </div>
                                    <div class="card-body">
                                        <div class="row">
                                            <div class="col-md-4 text-center">
                                                <img src="https://img.icons8.com/color/24/000000/anydesk.png">
                                            </div>
                                            <div class="col-md-8 text-left">
                                                <span class="small">
                                                    @Model.AnydeskID
                                                </span>
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-md-4 text-center">
                                                <span class="small">
                                                    <i class="material-icons">lock</i>
                                                </span>
                                            </div>
                                            <div class="col-md-8 text-left">
                                                <span class="small">
                                                    12312412345
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                        <div class="col-6">
                            <div class="card">
                                <div class="card-header text-center">
                                    <h5 class="card-title text-gray">Account</h5>
                                </div>
                                <div class="card-body">
                                    <form>
                                        <div class="row">
                                            <div class="col-12">
                                                <div class="form-group bmd-form-group">
                                                    <label class="bmd-label-floating">Type</label>
                                                    <input class="form-control" type="text" readonly value="DSL">
                                                </div>
                                                <div class="form-group bmd-form-group">
                                                    <label class="bmd-label-floating">Provider</label>
                                                    <input class="form-control" type="text" readonly value="Verizon">
                                                </div>
                                                <div class="form-group bmd-form-group">
                                                    <label class="bmd-label-floating">Plan</label>
                                                    <input class="form-control" type="text" readonly value="Shared">
                                                </div>
                                                <div class="form-group bmd-form-group">
                                                    <label class="bmd-label-floating">Account number</label>
                                                    <input class="form-control" type="text" readonly value="12356745">
                                                </div>
                                                <div class="form-group bmd-form-group">
                                                    <label class="bmd-label-floating">Mobile number</label>
                                                    <input class="form-control" type="text" readonly value="9177676186">
                                                </div>
                                                <div class="form-group bmd-form-group">
                                                    <label class="bmd-label-floating">Network Login</label>
                                                    <input class="form-control" type="text" readonly value="wdjfujeie">
                                                </div>
                                                <div class="form-group bmd-form-group">
                                                    <label class="bmd-label-floating">Password</label>
                                                    <input class="form-control" type="text" readonly value="was123">
                                                </div>
                                            </div>
                                        </div>
                                        <div class="clearfix"></div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-6">
                    <div class="card">
                        <div class="body">
                            <div id="UsageChart" style="width: 100%; height: 300px;"></div>
                            <div id="UptimeChart" style="width: 100%; height: 300px;"></div>
                        </div>
                    </div>
                    
                </div>
            </div>
        </div>
        <div class="col-md-2">
            <div class="card">
                <div class="card-body">
                    <div class="row">
                        <div class="col-6 right">
                            <a class="btn btn-primary btn-sm" asp-area="admin" asp-controller="node" asp-action="Edit" asp-route-location="@Html.ViewData["location"]" asp-route-node="@Model.Name">
                                <i class="material-icons text-white">edit</i>
                            </a>
                            <button class="btn btn-primary  btn-sm">
                                <i class="material-icons text-white">person_add</i>
                            </button>
                        </div>
                        <div class="col-6">
                            <button class="btn btn-primary  btn-sm">
                                <i class="material-icons text-white">data_usage</i>
                            </button>
                            <button class="btn btn-primary btn-sm">
                                <i class="material-icons text-white">calendar_today</i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title text-md-center small">Hardware</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-3 text-right">
                            <i class="material-icons">router</i>
                        </div>
                        <div class="col-9 text-left small">
                            @Model.Modem
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-3 text-center">
                            <i class="material-icons">speed</i>
                        </div>
                        <div class="col-9 text-left small">
                            3.5 Mbs
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-3 text-center">
                            <i class="material-icons">memory</i>
                        </div>
                        <div class="col-9 text-left small">
                            @Model.RAM GB
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-3 text-center">
                            <i class="material-icons">storage</i>
                        </div>
                        <div class="col-9 text-left small">
                            @if (Model.IsSSD)
                            {
                                <span>@Model.Storage SSD</span>
                            }
                            else
                            {
                                <span>@Model.Storage HDD</span>
                            }
                        </div>
                    </div>
                    @if (Model.MemoryStick)
                    {
                        <div class="row">
                            <div class="col-3 text-center">
                                <i class="material-icons">usb</i>
                            </div>
                            <div class="col-9 text-left small">
                                USB Dongle
                            </div>
                        </div>
                    }
                    @if (Model.NetworkAdapter)
                    {
                        <div class="row">
                            <div class="col-3 text-center">
                                <i class="material-icons">extension</i>
                            </div>
                            <div class="col-9 text-left small">
                                Relay
                            </div>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var myChart = Highcharts.chart('UsageChart', {
            chart: {
                type: 'line'
            },
            title: {
                text: 'Data Usage'
            },
            xAxis: {
                categories: @Html.Raw(Json.Serialize(Model.DatesUsage))
            },
            yAxis: {
                title: {
                    text: 'Data Used (GB)'
                }
            },
            plotOptions: {
                line: {
                    dataLabels: {
                        enabled: true
                    },
                    enableMouseTracking: true
                }
            },
            series: [{
                name: 'Provider',
                data: @Html.Raw(Json.Serialize(Model.Usage))
            }]
        });
    });
</script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var myChart = Highcharts.chart('UptimeChart', {
            chart: {
                type: 'column'
            },
            title: {
                text: 'Uptime'
            },
            xAxis: {
                categories: @Html.Raw(Json.Serialize(Model.DatesUptime))
            },
            yAxis: {
                min: 0,
                title: {
                    text: 'Total Uptime'
                }
            },
            tooltip: {
                pointFormat: '<span style="color:{series.color}">{series.name}</span>: <b>{point.y}</b> ({point.percentage:.0f}%)<br/>',
                shared: true
            },
            plotOptions: {
                column: {
                    stacking: 'percent'
                }
            },
            series: [{
                name: 'Service Internet',
                data: @Html.Raw(Json.Serialize(Model.ServiceInternet))
            }, {
                name: 'Offline',
                data: @Html.Raw(Json.Serialize(Model.DownTime))
            }, {
                name: 'Main Internet',
                data: @Html.Raw(Json.Serialize(Model.MainInternet))
            }]
        });
    });
</script>