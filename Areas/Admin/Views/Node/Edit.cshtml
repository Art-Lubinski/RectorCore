
@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";

}
@model RectorCore.ViewModels.NodeInfoEditViewModel
<div class="container-fluid ">
    <ul class="nav nav-pills justify-content-center">
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewData["location"].ToString() == "NY" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="NY">NY</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewData["location"].ToString() == "TX" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="TX">TX</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewBag.Location.ToString() == "FL" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="FL">FL</a>
        </li>
        <li class="nav-item active">
            <a class="nav-link @(ViewContext.ViewBag.Location.ToString() == "CA" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="CA">CA</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewBag.Location.ToString() == "IL" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="IL">IL</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewBag.Location.ToString() == "OH" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="OH">OH</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewBag.Location.ToString() == "AL" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="AL">AL</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewBag.Location.ToString() == "WA" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="WA">WA</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewBag.Location.ToString() == "AZ" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="AZ">AZ</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewBag.Location.ToString() == "AUS" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="AUS">AUS</a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewContext.ViewBag.Location.ToString() == "CAN" ? "active" : "")" asp-area="admin" asp-controller="nodes" asp-action="index" asp-route-location="CAN">CAN</a>
        </li>
    </ul>
    <div class="row">
        <div class="col-md-10">
            <div class="row ">
                <div class="col-6">
                    <div class="card">
                        <div class="card-body">
                            <form name="myform" asp-action="Save" asp-controller="Node" asp-route-node="@Model.Name">
                                <div class="row">
                                    <div class="col-12">
                                        <div class="form-group">
                                            <div class="form-group bmd-form-group">

                                                <div class="form-group bmd-form-group">
                                                    <label>Status</label>
                                                    <select asp-for="Status" asp-items="@Model.StatusListItems" class="form-control"></select>
                                                </div>
                                                <div class="form-group bmd-form-group">
                                                    <label>Phone Number</label>
                                                    <select asp-for="PhoneNumberID" asp-items="@Model.PhoneNumbers" class="form-control"></select>
                                                </div>
                                                <div class="form-group">
                                                    <div class="input-group">
                                                        <label asp-for="TVPassword" class="bmd-label-floating">
                                                            <img alt="svgImg" src="data:image/svg+xml;base64,">
                                                            Team-Viewer Password
                                                        </label>
                                                        <input id="TVPassword" asp-for="TVPassword" class="form-control" type="text" value="@Model.TVPassword">
                                                        <span class="input-group-btn">
                                                            <a onClick="generate('TVPassword')" class="btn btn-fab btn-fab-mini btn-round text-white">
                                                                <i class="material-icons">refresh</i>
                                                            </a>
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="form-group">
                                                    <div class="input-group">
                                                        <label asp-for="AnydeskPassword" class="bmd-label-floating"> <img src="https://img.icons8.com/color/12/000000/anydesk.png"> AnyDesk Password</label>
                                                        <input id="AnyDeskPassword" asp-for="AnydeskPassword" class="form-control" type="text" value="@Model.AnydeskPassword">
                                                        <span class="input-group-btn">
                                                            <a onClick="generate('AnyDeskPassword')" class="btn btn-fab btn-fab-mini btn-round text-white">
                                                                <i class="material-icons">refresh</i>
                                                            </a>
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <button class="btn btn-danger btn-sm pull-left">
                                    <i class="material-icons text-white">delete</i>
                                </button>
                                <button type="submit" class="btn btn-primary pull-right">Update</button>
                                <div class="clearfix"></div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<script>
    function randomPassword(length) {
        var chars = "abcdefghkmnpqrstuvwxyzABCDEFGHKLMNP23456789.&#!";
        var pass = "";
        for (var x = 0; x < length; x++) {
            var i = Math.floor(Math.random() * chars.length);
            pass += chars.charAt(i);
        }
        return pass;
    }

    function generate(id) {
        document.getElementById(id).value = randomPassword(10);
    }
</script>